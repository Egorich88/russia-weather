          "language": "go",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "<div style=\"display: flex; align-items: flex-start; justify-content: space-between; padding: 10px;\">\n    \n    <!-- Колонка 1: Местное время + ссылка Gismeteo (ИСПРАВЛЕНО) -->\n    <div style=\"text-align: center; min-width: 120px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Время</div>\n        <!-- ВРЕМЯ -->\n        <div style=\"font-size: 36px; font-weight: bold; line-height: 1.2;\">${__from:date:HH:mm}</div>\n        <!-- Ссылка под временем -->\n        <div style=\"font-size: 14px; margin-top: 8px; color: #fff;\">\n            По данным <a href=\"https://www.gismeteo.ru\" target=\"_blank\" style=\"color: #3399ff; text-decoration: underline;\">www.Gismeteo.ru</a>\n        </div>\n    </div>\n    \n    <!-- Колонка 2: Температура -->\n    <div style=\"text-align: center; min-width: 100px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Температура</div>\n        <div style=\"font-size: 36px; font-weight: bold; line-height: 1.2;\">${temperature}°C</div>\n    </div>\n    \n    <!-- Колонка 3: Ощущается -->\n    <div style=\"text-align: center; min-width: 100px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Ощущается</div>\n        <div style=\"font-size: 36px; font-weight: bold; line-height: 1.2;\">${feels_like}°C</div>\n    </div>\n    \n    <!-- Колонка 4: Небо (иконка + описание) -->\n    <div style=\"text-align: center; min-width: 120px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Небо</div>\n        <img src=\"/public/img/icons/gismeteo/${icon_code}.png\" style=\"width: 70px; height: 70px; margin-bottom: 5px;\">\n        <div style=\"font-size: 14px; font-weight: 500; color: #666;\">${description}</div>\n    </div>\n    \n    <!-- Колонка 5: Влажность -->\n    <div style=\"text-align: center; min-width: 80px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Влажность</div>\n        <div style=\"font-size: 36px; font-weight: bold; line-height: 1.2;\">${humidity}%</div>\n    </div>\n    \n    <!-- Колонка 6: Ветер -->\n    <div style=\"text-align: center; min-width: 90px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Ветер</div>\n        <div style=\"font-size: 36px; font-weight: bold; line-height: 1.2;\">${wind_speed} м/с</div>\n    </div>\n    \n    <!-- Колонка 7: Давление -->\n    <div style=\"text-align: center; min-width: 100px; margin-right: 20px;\">\n        <div style=\"font-size: 16px; color: #666; margin-bottom: 2px;\">Давление</div>\n        <div style=\"font-size: 36px; font-weight: bold; line-height: 1.2;\">${pressure}</div>\n        <div style=\"font-size: 14px; color: #666;\">мм рт. ст.</div>\n    </div>\n    \n</div>",
        "mode": "html"
      },
